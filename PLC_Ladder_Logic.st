PROGRAM program0
  VAR
    ConveyorOnOff AT %QX0.0 : BOOL := 1;
    Motor AT %QX0.1 : BOOL := 0;
    Pulse AT %QX0.2 : BOOL := 0;
    ResetCounters AT %QX0.3 : BOOL := 0;
    BoxWeight AT %MW0 : INT := 0;
    SmallCounterCount AT %MW4 : INT := 0;
    MediumCounterCount AT %MW3 : INT := 0;
    BigCounterCount AT %MW2 : INT := 0;
    TotalCount AT %MW1 : INT := 0;
  END_VAR
  VAR
    SmallCounter : CTU;
    MediumCounter : CTU;
    BigCounter : CTU;
    TOF0 : TOF;
    SmallTrigger : BOOL;
    MedTrigger : BOOL;
    BigTrigger : BOOL;
    TOF1 : TOF;
    TOF2 : TOF;
    TOF3 : TOF;
    R_TRIG1 : R_TRIG;
    _TMP_EQ77_OUT : BOOL;
    _TMP_OR74_OUT : BOOL;
    R_TRIG2 : R_TRIG;
    R_TRIG3 : R_TRIG;
    _TMP_LT8_OUT : BOOL;
    _TMP_LT20_OUT : BOOL;
    _TMP_GT55_OUT : BOOL;
    _TMP_AND56_OUT : BOOL;
    _TMP_GT25_OUT : BOOL;
    _TMP_ADD86_OUT : INT;
  END_VAR

  R_TRIG1(CLK := SmallTrigger);
  SmallCounter(CU := R_TRIG1.Q, R := ResetCounters, PV := 50);
  SmallCounterCount := SmallCounter.CV;
  _TMP_EQ77_OUT := EQ(BoxWeight, 0);
  TOF3(IN := _TMP_EQ77_OUT, PT := T#300ms);
  TOF0(IN := SmallTrigger, PT := T#4.75s);
  TOF1(IN := MedTrigger, PT := T#3s);
  TOF2(IN := BigTrigger, PT := T#2s);
  _TMP_OR74_OUT := OR(TOF3.Q, TOF0.Q, TOF1.Q, TOF2.Q);
  Motor := ConveyorOnOff AND _TMP_OR74_OUT;
  R_TRIG2(CLK := MedTrigger);
  MediumCounter(CU := R_TRIG2.Q, R := ResetCounters, PV := 50);
  MediumCounterCount := MediumCounter.CV;
  R_TRIG3(CLK := BigTrigger);
  BigCounter(CU := R_TRIG3.Q, R := ResetCounters, PV := 50);
  BigCounterCount := BigCounter.CV;
  _TMP_LT8_OUT := LT(BoxWeight, 6);
  SmallTrigger := Pulse AND _TMP_LT8_OUT;
  _TMP_LT20_OUT := LT(BoxWeight, 11);
  _TMP_GT55_OUT := GT(BoxWeight, 5);
  _TMP_AND56_OUT := AND(_TMP_LT20_OUT, _TMP_GT55_OUT);
  MedTrigger := Pulse AND _TMP_AND56_OUT;
  _TMP_GT25_OUT := GT(BoxWeight, 10);
  BigTrigger := Pulse AND _TMP_GT25_OUT;
  _TMP_ADD86_OUT := ADD(BigCounterCount, MediumCounterCount, SmallCounterCount);
  TotalCount := _TMP_ADD86_OUT;
END_PROGRAM


CONFIGURATION Config0

  RESOURCE Res0 ON PLC
    TASK task0(INTERVAL := T#20ms,PRIORITY := 0);
    PROGRAM instance0 WITH task0 : program0;
  END_RESOURCE
END_CONFIGURATION

